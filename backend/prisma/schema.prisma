generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id @default(uuid())
  ownerId             String?
  claimTokenHash      String?
  claimTokenExpiresAt DateTime?
  status              String    @default("created")
  conversationText    String?
  rawAnswers          Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  business            Business?
  websites            Website[]

  @@index([ownerId])
}

model Business {
  id                 String   @id @default(uuid())
  sessionId          String   @unique
  ownerId            String?
  businessName       String
  businessType       String
  productsOrServices String
  location           String
  targetCustomers    String
  uniqueSellingPoint String
  websiteVibe        String
  extraFeatures      String
  tagline            String
  shortDescription   String
  contactHint        String
  competitorReference String   @default("")
  missingFields      Json
  confidence         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  websites           Website[]

  @@index([ownerId])
}

model Website {
  id          String    @id @default(uuid())
  sessionId   String
  businessId  String
  ownerId     String?
  slug        String    @unique
  status      String    @default("preview")
  templateId  String
  styleTokens Json
  siteContent Json
  seo         Json
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([businessId])
  @@index([ownerId])
  @@index([slug])
}

NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000

# Required when using Prisma/PostgreSQL routes.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wouessi_backend?schema=public"

# Optional. If omitted, backend returns deterministic demo-safe fallback AI outputs.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
